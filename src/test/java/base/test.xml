<?xml version="1.0" encoding="UTF-8"?>
<usecase>
    <counters>true</counters>
    <db>true</db>
    <release>release_9</release>
    <rules>
        <initial>
            <cca id="0">
                <requestType>INITIAL_REQUEST</requestType>
                <ruleRemove>
                    <name>Default Service Plan</name>
                </ruleRemove>
                <ruleInstall>
                    <name>SP1</name>
                </ruleInstall>
                <revalidationTimeOut>
                </revalidationTimeOut>
                <volume>
                    <rule name="Session" monitoring-level="session_level" totalVolume="4194304"></rule>
                    <rule name="Apps and voip" monitoring-level="pcc_rule_level" totalVolume="4194304"
                          inputVolume="1048576" outputVolume="2097152"></rule>
                    <rule name="HTTP" monitoring-level="pcc_rule_level" totalVolume="1048576"></rule>
                    <rule name="P2P" monitoring-level="pcc_rule_level" totalVolume="1048576"></rule>
                    <!--rule name="web_app" monitoring-level="pcc_rule_level" totalVolume="3932160"></rule-->
                </volume>

            </cca>
        </initial>
        <ongoing>
            <cca id="1">
                <requestType>UPDATE_REQUEST</requestType>
                <return-code>5006</return-code>
                <ruleRemove>
                    <name>SP1</name>
                </ruleRemove>
                <ruleInstall>
                    <name>Default Service Plan</name>
                </ruleInstall>
                <revalidationTimeOut>
                    <value>5</value>
                    <unit>MINUTE</unit>
                </revalidationTimeOut>
                <volume>
                    <rule name="HTTP" monitoring-level="pcc_rule_level" totalVolume="4194304"></rule>
                    <rule name="P2P" monitoring-level="pcc_rule_level" totalVolume="4194304"></rule>
                    <rule name="Apps and voip" monitoring-level="pcc_rule_level" totalVolume="4194304"></rule>
                </volume>
            </cca>
            <cca id="0">
                <requestType>UPDATE_REQUEST</requestType>
                <multipleServicesCC>
                    <grantedServiceUnit ccTotalOctets="9000000000"/>
                    <serviceIdentifier>100</serviceIdentifier>
                    <ratingGroup>100</ratingGroup>
                </multipleServicesCC>
                <rarId>0</rarId>
            </cca>
            <rar id="0">
                <delay>30000</delay> <!-- ms -->
                <multipleServicesCC>
                    <serviceIdentifier>100</serviceIdentifier>
                    <ratingGroup>110</ratingGroup>
                </multipleServicesCC>
            </rar>
        </ongoing>
    </rules>
</usecase>